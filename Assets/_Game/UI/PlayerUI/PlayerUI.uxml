                    <ui:Label text="T" style="position: absolute; top: 3px; left: 18px; font-size: 8px; color: rgba(200, 160, 80, 0.5); -unity-font-style: bold;"/>
                    <ui:VisualElement style="position: absolute; top: 0; left: -4px; width: 55%; height: 100%; background-color: rgba(50, 110, 155, 0.75); align-items: flex-start; justify-content: flex-start; padding: 9px 0 0 6px;">
                        <ui:VisualElement style="position: absolute; bottom: 36%; right: 4px; width: 6px; height: 6px; border-radius: 3px; border-width: 1px; border-color: rgba(6, 8, 20, 0.9); background-color: rgb(128, 200, 232);"/>
                    </ui:VisualElement>

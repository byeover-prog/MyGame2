                        <ui:VisualElement name="DashPip1" style="width: 30px; height: 15px; border-radius: 1px; margin-right: 3px; background-color: rgb(80, 150, 200); border-top-right-radius: 100px; border-bottom-right-radius: 100px;"/>
                        <ui:VisualElement name="DashPip2" style="width: 16px; height: 8px; border-radius: 1px; margin-right: 3px; background-color: rgb(112, 208, 144); display: none;"/>

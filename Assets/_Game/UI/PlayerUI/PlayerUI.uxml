<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="HUDRoot" style="position: absolute; left: 1px; top: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, 0); -unity-font-definition: url(&quot;project://database/Assets/ThirdParty/NanumFontSetup_OTF_BARUNGOTHIC/MaruBuri-Bold.otf?fileID=12800000&amp;guid=fb6c55dec66ad7842a8675f9be114037&amp;type=3#MaruBuri-Bold&quot;);">
        <ui:VisualElement name="TopBar" style="position: absolute; left: 0; top: 0; right: 0; height: 9px; flex-direction: row; align-items: center; background-color: rgba(6, 10, 22, 0.85); border-bottom-width: 1px; border-bottom-color: rgba(200, 160, 80, 0.2);">
            <ui:Label name="LevelLabel" text="Lv.1" style="font-size: 20px; color: rgb(255, 255, 255); -unity-font-style: bold; padding-left: 8px; padding-right: 6px; flex-shrink: 0; -unity-text-align: middle-left; top: 7px; background-color: rgb(6, 10, 22); -unity-background-scale-mode: stretch-to-fill; background-position-y: center; border-bottom-right-radius: 8px; -unity-slice-left: 0; -unity-slice-top: 0; -unity-slice-right: 0; -unity-slice-bottom: 0; -unity-slice-type: sliced; position: relative; flex-grow: 0; height: 23px; right: 2px;"/>
            <ui:VisualElement name="XPBarBg" style="flex-grow: 1; height: 6px; margin-right: 8px; background-color: rgba(255, 255, 255, 0.08); border-radius: 1px; overflow: hidden; position: relative;">
                <ui:VisualElement name="XPBarFill" style="position: absolute; left: 0; top: 0; bottom: 0; width: 35%; background-color: rgb(96, 168, 240);"/>
                <ui:VisualElement style="position: absolute; left: 20%; top: 0; bottom: 0; width: 1px; background-color: rgba(0, 0, 0, 0.35);"/>
                <ui:VisualElement style="position: absolute; left: 40%; top: 0; bottom: 0; width: 1px; background-color: rgba(0, 0, 0, 0.35);"/>
                <ui:VisualElement style="position: absolute; left: 60%; top: 0; bottom: 0; width: 1px; background-color: rgba(0, 0, 0, 0.35);"/>
                <ui:VisualElement style="position: absolute; left: 80%; top: 0; bottom: 0; width: 1px; background-color: rgba(0, 0, 0, 0.35);"/>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="TimerBox" style="position: absolute; top: 30px; background-color: rgba(6, 8, 20, 0.75); border-width: 1px; border-color: rgba(200, 160, 80, 0.3); padding: 4px 18px; right: auto; align-items: flex-start; left: 50%; height: 50px;">
            <ui:Label name="TimerLabel" text="00 : 00" style="font-size: 20px; color: rgb(200, 160, 80); -unity-font-style: bold; -unity-text-align: middle-center;"/>
        </ui:VisualElement>
        <ui:VisualElement name="StatsPanel" style="position: absolute; top: 30px; right: 10px; flex-direction: column; align-items: flex-end;">
            <ui:VisualElement style="flex-direction: row; align-items: center; min-width: 130px; padding: 4px 10px 4px 8px; margin-bottom: 2px; background-color: rgba(6, 10, 22, 0.75); border-right-width: 1px; border-right-color: rgba(200, 160, 80, 0.2);">
                <ui:VisualElement style="width: 14px; height: 14px; border-width: 1px; border-color: rgba(200, 160, 80, 0.5); align-items: center; justify-content: center; margin-right: 8px; flex-shrink: 0;">
                    <ui:VisualElement style="width: 6px; height: 6px; rotate: 45deg; background-color: rgb(200, 160, 80);"/>
                </ui:VisualElement>
                <ui:Label text="냥" style="font-size: 9px; color: rgb(106, 90, 64); flex-grow: 1;"/>
                <ui:Label name="NyangValue" text="0" style="font-size: 13px; color: rgb(232, 200, 120); -unity-font-style: bold;"/>
            </ui:VisualElement>

                        <ui:VisualElement style="position: absolute; top: 36%; left: 4px; width: 6px; height: 6px; border-radius: 3px; border-width: 1px; border-color: rgba(6, 8, 20, 0.9); background-color: rgb(128, 80, 200);"/>

                <ui:VisualElement style="width: 14px; height: 14px; border-width: 1px; border-color: rgba(128, 80, 200, 0.5); align-items: center; justify-content: center; margin-right: 8px; flex-shrink: 0;">
                    <ui:VisualElement style="width: 6px; height: 6px; rotate: 45deg; background-color: rgb(128, 80, 200);"/>

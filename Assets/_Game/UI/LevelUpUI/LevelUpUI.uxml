            <ui:Button name="BtnMinimize" text="최소화" style="width: 100px; height: 32px; margin-right: 10px; background-color: rgba(6, 8, 20, 0.9); border-width: 1px; border-color: rgba(200, 160, 80, 0.3); color: rgb(106, 90, 64); font-size: 11px;"/>
            <ui:Button name="BtnReroll" text="새로고침" style="width: 100px; height: 32px; background-color: rgba(6, 8, 20, 0.9); border-width: 1px; border-color: rgba(200, 160, 80, 0.5); color: rgb(200, 160, 80); font-size: 11px;"/>
